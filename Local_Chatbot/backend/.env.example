APP_NAME=Local Chatbot API
APP_ENV=development
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/local_chatbot
LANGGRAPH_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/local_chatbot?sslmode=disable

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=local_chatbot_documents
QDRANT_ROUTING_COLLECTION=local_chatbot_kb_routes
QDRANT_PREFER_GRPC=false

UPLOADS_DIR=storage/uploads
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.25
RAG_CHUNK_SIZE=900
RAG_CHUNK_OVERLAP=150
KB_ROUTING_TOP_K=3
KB_ROUTING_SCORE_THRESHOLD=0.2
KB_ROUTING_SCORE_MARGIN=0.08
KB_ROUTING_MAX_DOCUMENT_PREVIEWS=4
KB_ROUTING_PREVIEW_CHARS=320

LLM_MODEL=openai:gpt-4.1-mini
LLM_TEMPERATURE=0.2
OPENAI_API_KEY=
OPENAI_BASE_URL=

EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
